# Copy to `.env` and fill in real values. `.env` is git-ignored (holds secrets).
# The package auto-loads this file on import; process env vars always take precedence.

# ---- Langfuse tracing (optional; missing -> runs untraced, never errors) ----
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=http://localhost:3000

# ---- SearXNG search (required for provider="searxng"; else falls back to duckduckgo) ----
SEARXNG_BASE_URL=http://localhost:3002/

# ---- LLM (OpenAI-compatible; DashScope qwen-plus by default) ----
# LLM_KEY unset -> decompose/plan/score degrade to the no-LLM path.
# A trailing /chat/completions is stripped automatically.
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_KEY=
# LLM_MODEL=qwen-plus

# ---- EDRE local cross-encoder reranker (optional override) ----
# EDRE_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# On a cold cache the reranker downloads the model from Hugging Face. If
# huggingface.co is blocked (e.g. inside mainland China), point at a mirror so
# the real EDRE E2E (§9) can fetch it. Loaded before the lazy CrossEncoder import.
# HF_ENDPOINT=https://hf-mirror.com
